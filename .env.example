# Mutable source tags. `hermes.ps1 init` resolves each to an immutable digest.
HERMES_SOURCE_IMAGE=nousresearch/hermes-agent:latest
NETGUARD_SOURCE_IMAGE=debian:bookworm-slim
STATE_INIT_SOURCE_IMAGE=busybox:1.37.0
MIHOMO_SOURCE_IMAGE=metacubex/mihomo:latest

# Filled automatically by `hermes.ps1 init` / `hermes.ps1 update`.
HERMES_IMAGE_REF=
NETGUARD_IMAGE_REF=
STATE_INIT_IMAGE_REF=
MIHOMO_IMAGE_REF=

HERMES_RUNTIME_IMAGE=hermes-secure-runtime:local
NETGUARD_RUNTIME_IMAGE=hermes-secure-netguard:local
HERMES_DATA_VOLUME=hermes-secure-data
MIHOMO_DATA_VOLUME=hermes-secure-mihomo-data

HERMES_MEMORY_LIMIT=6g
HERMES_CPU_LIMIT=4.0
HERMES_SHM_SIZE=1g
MIHOMO_MEMORY_LIMIT=512m
MIHOMO_CPU_LIMIT=1.0
HERMES_LOOPBACK_TCP_PORTS=3128,9119
MIHOMO_TCP_PORTS=80,443,8443,2053,2083,2087,2096
TZ=Asia/Singapore
